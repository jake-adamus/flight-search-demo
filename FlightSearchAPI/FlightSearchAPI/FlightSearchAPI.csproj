<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.8" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.2.1" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Resources\" />
  </ItemGroup>

  <Target Name="copyAirports" AfterTargets="AfterBuild">
    <Copy SourceFiles="Resources/airports.json" DestinationFolder="$(OutDir)" />
  </Target>
  <Target Name="copyFlights" AfterTargets="AfterBuild">
    <Copy SourceFiles="Resources/flights.json" DestinationFolder="$(OutDir)" />
  </Target>
  <Target Name="copyRoutes" AfterTargets="AfterBuild">
    <Copy SourceFiles="Resources/routes.json" DestinationFolder="$(OutDir)" />
  </Target>

</Project>
